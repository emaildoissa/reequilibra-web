# ==============================================================================
# Reequilibra Web - Configuração do Git Ignore (Segurança & Organização)
# ==============================================================================

# --- Dependências de Pacotes ---
node_modules/
/jspm_packages/
/web_modules/

# --- Compilação, Build e Cache ---
dist/
dist-ssr/
build/
out/
.vite/
.eslintcache
.parcel-cache
.cache/

# --- SEGURANÇA E SEGREDOS (MUITO IMPORTANTE) ---
# Jamais envie chaves de API, credenciais ou variáveis locais para o GitHub!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
certs/
secrets/

# --- Logs e Arquivos de Debug ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testes e Cobertura ---
coverage/
.nyc_output/
.playwright/
/test-results/

# --- Configurações de IDEs / Editores ---
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/

# Sistema Operacional e outros editores
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# --- Ferramentas de IA / Agentes Locais ---
# Ignorar arquivos temporários, relatórios e caches de agentes de IA
.agents/
.impeccable/
*.gemini/
